# ─── Backend API ──────────────────────────────────────────────────────────────
# Your Render backend URL. NO trailing slash. NO /api suffix.
# Example: https://stashpot-backend.onrender.com
VITE_API_URL=https://stashpot-backend.onrender.com

# ─── Privy (auth + embedded wallets) ──────────────────────────────────────────
# Get this from https://dashboard.privy.io
# 1. Create a new app
# 2. Settings → Basics → copy the App ID
# 3. Login Methods → enable: Email, Google, Apple, Passkey, External Wallets
# 4. Wallets → enable Solana
# 5. Allowed Origins → add http://localhost:5173 and your Vercel domain
VITE_PRIVY_APP_ID=

# ─── Solana ───────────────────────────────────────────────────────────────────
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com
VITE_SOLANA_MAINNET_RPC_URL=https://api.mainnet-beta.solana.com
VITE_NETWORK=devnet
